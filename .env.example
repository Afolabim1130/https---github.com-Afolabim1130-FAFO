# FAFO sample environment configuration

# Evidence storage path relative to app root
EVIDENCE_REPOSITORY=./evidence_repository

# Upload limits
MAX_UPLOAD_SIZE_MB=100

# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30

# SMTP Email Alerts
SMTP_ENABLED=False
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=fafo-notifications@example.com

# Optional binary paths
OCR_TESSERACT_PATH=
FFMPEG_PATH=ffmpeg
